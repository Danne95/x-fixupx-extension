{
  "manifest_version": 3,
  "name": "xfixupx",
  "version": "1.0.0",
  "description": "Adds a 'Copy Link Fixup' option to X.com share menus, replacing x.com with fixupx.com for better link previews.",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_v2_16.png",
      "32": "icons/icon_v2_32.png",
      "48": "icons/icon_v2_48.png",
      "128": "icons/icon_v2_128.png"
    }
  },
  "icons": {
    "16": "icons/icon_v2_16.png",
    "32": "icons/icon_v2_32.png",
    "48": "icons/icon_v2_48.png",
    "128": "icons/icon_v2_128.png"
  }
}
